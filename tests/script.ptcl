unsyntax {
	prototype function printf(content: character*, ...): integer
	prototype function printn(content: integer, ...): integer
	prototype function printc(content: character, ...): integer
	prototype function strlen(content: const character*): integer
	prototype function malloc(size: integer): pointer
}

function print(content: any): static void {
	if content is integer {
		printn(content :: integer)
	}
	else {
		if content is character* {
			printf(content :: character*)
		}
		else {
			if content is character {
				printc(content :: character)
			}
		}
	}
}

syntax object_name [name: static word] {
	!<__object_ !name>
}

syntax object [name: static word] [{] [variables: ...] [}] with [body: static (): void] {
	~typedata_name: static word = #object_name(name)
	typedata !~typedata_name(ptcl_insert(variables))
	type !name: !~typedata_name {
		ptcl_insert(ptcl_get_statements(body))
	}
}

syntax create [name: static word]([arguments: ...]) {
	@{
		~instance := (!name) #object_name(name)(!none)
		~instance.constructor(ptcl_insert(arguments))
	}

	~instance
}

syntax delete [name: any] {
	name.destructor()
}

function main(): integer {
	val: static character[] = "123112222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222222112048--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------"
	each d, val {
		#object dog {
			name: character*,
			years: integer,
			created: integer
		} with {
			function constructor(name: character*, years: integer): void {
				self.name = name
				self.years = years
				self.created = 1
			}

			function destructor(): void {
				self.created = 0
			}

			function speak(): void {
				printf(self.name)
			}
		}
	}
	
	return 0
}